# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─── OpenTimestamps calendar servers ─────────────────────────────────────────
OTS_CALENDAR_URL_1=https://alice.btc.calendar.opentimestamps.org
OTS_CALENDAR_URL_2=https://bob.btc.calendar.opentimestamps.org

# ─── RFC 3161 TSA (Actalis, free tier, no registration needed for low volume) ─
TSA_URL=https://tsa.actalis.it/TSA/tss-usr-gen

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yousaidthat.org

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Vercel Cron (protects /api/cron/ots-poll from external calls) ────────────
CRON_SECRET=change-me-to-a-random-32-char-string

# ─── Frontend (used by Vite at build time) ────────────────────────────────────
# In development, API is served on the same origin (leave empty).
# In production, set to the backend URL if deploying separately (Railway/Render).
VITE_API_URL=
