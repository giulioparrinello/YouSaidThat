{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/index.cjs"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/ots-poll",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/arweave-retry",
      "schedule": "0 * * * *"
    }
  ]
}
